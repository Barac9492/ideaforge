# ── IdeaForge configuration ──────────────────────────────────────────────
# With NONE of these set, the app runs in bring-your-own-key mode and costs
# you $0. Set the group below to turn on a rate-limited free tier.

# 1) Your server key that powers free runs. Use a DEDICATED Anthropic workspace
#    with a hard monthly spend cap — that cap is your guaranteed worst case.
ANTHROPIC_API_KEY=

# 2) Rate-limit store (Upstash Redis, free tier). Free runs are DISABLED unless
#    both of these exist — so there's no way to be accidentally wide open.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# 3) Show the "free to try" banner (only set to 1 once the group above is live).
NEXT_PUBLIC_FREE_TIER=

# 4) Free-tier caps (optional; sensible defaults shown).
FREE_RUNS_PER_IP_PER_DAY=5
FREE_RUNS_GLOBAL_PER_DAY=200

# 5) Cloudflare Turnstile bot check (optional). If unset, the check is skipped.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
