# ── IdeaForge configuration ──────────────────────────────────────────────
# With the free-tier group unset, the app runs in bring-your-own-key mode and
# costs you $0. The free tier turns ON only when ALL FIVE required vars below
# are set — missing any one means BYO-only (safe by default). Turnstile is now
# REQUIRED for the free tier (not optional).

# 1) Server key that powers free runs. Use a DEDICATED Anthropic workspace with
#    a hard monthly spend cap — that cap is your guaranteed worst case.
ANTHROPIC_API_KEY=

# 2) Rate-limit store (Upstash Redis, free tier). Quota keys reset on KST day.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# 3) Cloudflare Turnstile (REQUIRED for free tier). Both must be set.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# 4) Flip the "free to try" banner copy on (set to 1 only once 1–3 are live).
NEXT_PUBLIC_FREE_TIER=

# 5) Free-tier caps (optional; sensible defaults shown).
FREE_RUNS_PER_IP_PER_DAY=5
FREE_RUNS_GLOBAL_PER_DAY=200

# 6) Canonical site URL for metadata/OG (optional; defaults to the prod domain).
NEXT_PUBLIC_SITE_URL=
